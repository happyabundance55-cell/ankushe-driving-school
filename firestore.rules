rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function signedIn() { return request.auth != null; }

    function hasUser() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMember(tid) {
      return hasUser() && myUser().tenantId == tid;
    }

    function hasRole(tid, roles) {
      return isMember(tid) && myUser().role in roles;
    }

    function isStudentSelf(tid, sid) {
      return isMember(tid) && myUser().role == 'student' && myUser().studentId == sid;
    }

    function isSuperadmin() {
      return signedIn() && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Billing fields are written only by the Cloudflare Worker (Admin SDK,
    // bypasses rules entirely) after a verified Cashfree payment, or by a
    // superadmin — never by a tenant admin's own client, since billingStatus
    // gates access to the whole admin app.
    function billingKeysUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['plan', 'billingStatus', 'trialEndsAt', 'currentPeriodEnd', 'studentCap',
         'waNotifications', 'referredByTenantId', 'referralCredited']
      );
    }

    // ── Active-student cap: rules-enforced counter consistency ─────────────
    // tenants/{tid}.activeStudentCount is a denormalized count of status:
    // 'active' students, kept trustworthy (can't drift from reality, can't
    // be moved by a client bypassing the app's UI) by requiring every write
    // that changes it to be paired, in the same atomic batch, with a real,
    // verified matching transition on a specific student doc. getAfter()
    // lets one document's rule see another document's state *after* the
    // whole batch would apply, which is what makes this checkable at all.
    // See db.js's ensureActiveStudentCountInitialized/createStudent/
    // approveStudent/deactivateStudent/reactivateStudent for the client half.
    //
    // Safe to deploy alongside the client changes in one shot: a tenant that
    // has never had activeStudentCount set yet gets a one-time bootstrap
    // allowance below (no prior value to verify against), which db.js
    // exercises automatically on the tenant's very next admin page load.

    // From the student doc's side: a brand-new doc starting life as 'active'.
    // .get(key, default) everywhere below, not dot-access — a tenant created
    // before this feature existed (or before billing settled studentCap via
    // the Worker) may genuinely be missing these keys rather than having
    // them set to null, and dot-access on an absent map key is an
    // evaluation error (denies the whole write), not a graceful null/false.
    // Already been bitten by this once for student.status; not leaving the
    // same class of bug in the tenant-doc fields too.
    function studentCapRespectedOnCreate(tid) {
      return request.resource.data.get('status', null) != 'active' || (
        getAfter(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0)
          == get(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0) + 1
        && (get(/databases/$(database)/documents/tenants/$(tid)).data.get('studentCap', null) == null
            || getAfter(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0)
                 <= get(/databases/$(database)/documents/tenants/$(tid)).data.get('studentCap', null))
      );
    }

    // From the student doc's side: an existing doc transitioning to/from 'active'.
    function studentCapRespectedOnUpdate(tid) {
      return (resource.data.get('status', null) == 'active') == (request.resource.data.get('status', null) == 'active') || (
        resource.data.get('status', null) != 'active' && request.resource.data.get('status', null) == 'active' && (
          getAfter(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0)
            == get(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0) + 1
          && (get(/databases/$(database)/documents/tenants/$(tid)).data.get('studentCap', null) == null
              || getAfter(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0)
                   <= get(/databases/$(database)/documents/tenants/$(tid)).data.get('studentCap', null))
        )
      ) || (
        resource.data.get('status', null) == 'active' && request.resource.data.get('status', null) != 'active'
          && getAfter(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0)
               == get(/databases/$(database)/documents/tenants/$(tid)).data.get('activeStudentCount', 0) - 1
      );
    }

    // From the tenant doc's side (mirrors the two functions above): a
    // counter change must be backed by a real, verified transition on the
    // specific student named in _capEventStudentId — otherwise a client
    // could decrement with no real deactivation, bank that fake headroom,
    // then legitimately activate an extra real student later.
    function activeStudentCountChangeVerified(tid) {
      return resource.data.get('activeStudentCount', null) == request.resource.data.get('activeStudentCount', null) || (
        // One-time bootstrap: the field has never existed on this tenant
        // before (see ensureActiveStudentCountInitialized in db.js, called
        // from bootstrapPage on every admin page load) — nothing to verify
        // it against yet, so allow setting it once, and only it (no other
        // field may ride along in the same write). Once set, this branch
        // can never apply again for this tenant — 'activeStudentCount' in
        // resource.data is now true forever, so every future change is
        // forced through the strict paired-verification branches below.
        (!('activeStudentCount' in resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeStudentCount'])
          && request.resource.data.activeStudentCount is int
          && request.resource.data.activeStudentCount >= 0)
      ) || (
        request.resource.data.get('activeStudentCount', 0) == resource.data.get('activeStudentCount', 0) + 1
          // The referenced student may not exist yet before this batch — a
          // brand-new student created directly as 'active' (createStudent())
          // is exactly that case, not just a pending->active transition.
          && (!exists(/databases/$(database)/documents/tenants/$(tid)/students/$(request.resource.data._capEventStudentId))
              || get(/databases/$(database)/documents/tenants/$(tid)/students/$(request.resource.data._capEventStudentId)).data.get('status', null) != 'active')
          && getAfter(/databases/$(database)/documents/tenants/$(tid)/students/$(request.resource.data._capEventStudentId)).data.get('status', null) == 'active'
          && (resource.data.get('studentCap', null) == null || request.resource.data.get('activeStudentCount', 0) <= resource.data.get('studentCap', null))
      ) || (
        request.resource.data.get('activeStudentCount', 0) == resource.data.get('activeStudentCount', 0) - 1
          && get(/databases/$(database)/documents/tenants/$(tid)/students/$(request.resource.data._capEventStudentId)).data.get('status', null) == 'active'
          && getAfter(/databases/$(database)/documents/tenants/$(tid)/students/$(request.resource.data._capEventStudentId)).data.get('status', null) != 'active'
      );
    }

    // Firebase Phone Auth sets this automatically on the ID token — verified
    // server-side at OTP sign-in, not something the client can forge.
    function verifiedPhone() {
      return signedIn() ? request.auth.token.phone_number : null;
    }

    // ── Tenant directory (public, non-sensitive) ────────────────────────────
    match /tenantSlugs/{slug} {
      allow read: if true; // must be resolvable before anyone is signed in
      // Only created as half of the atomic signup batch — see /tenants/{tid} below.
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['tenantId'])
        && request.resource.data.tenantId is string
        && !exists(/databases/$(database)/documents/tenantSlugs/$(slug));
      allow update, delete: if false;
    }

    // ── Tenant settings ──────────────────────────────────────────────────────
    match /tenants/{tid} {
      // Public: login.html and the referral banner need this pre-auth (to show
      // school name/branding before anyone signs in). Nothing here is sensitive
      // — name/address are already shown publicly on the login page and forms.
      allow read: if true;
      // Self-provisioning: brand-new tenant only. Rules see pre-batch state, so
      // this and the matching /users/{uid} admin-create rule can only ever both
      // succeed together for a tenant ID that doesn't exist yet.
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && !exists(/databases/$(database)/documents/tenants/$(tid));
      allow update: if (hasRole(tid, ['admin']) && billingKeysUnchanged() && activeStudentCountChangeVerified(tid)) || isSuperadmin();
      allow delete: if false;
    }

    // Platform-level admins (not tenant-scoped). Seeded manually — never
    // client-writable, purely a marker doc checked by isSuperadmin() above.
    match /superadmins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Identity: users/{uid}, keyed by Firebase Auth UID ──────────────────
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || hasRole(resource.data.tenantId, ['admin']));

      // Admin: only as the other half of a brand-new tenant signup batch.
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'admin'
        && !exists(/databases/$(database)/documents/users/$(uid))
        && !exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId));

      // Mentor: only by linking a matching admin-created invite, phone-verified.
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'mentor'
        && !exists(/databases/$(database)/documents/users/$(uid))
        && verifiedPhone() == request.resource.data.phone
        && exists(/databases/$(database)/documents/pendingInvites/$(request.resource.data.phone))
        && get(/databases/$(database)/documents/pendingInvites/$(request.resource.data.phone)).data.tenantId == request.resource.data.tenantId
        && get(/databases/$(database)/documents/pendingInvites/$(request.resource.data.phone)).data.role == 'mentor';

      // Student — linking: an admin already enrolled this phone number
      // (tenants/{tid}/studentsByPhone/{phone} exists) — attach to that
      // existing student record rather than creating a new one.
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'student'
        && !exists(/databases/$(database)/documents/users/$(uid))
        && verifiedPhone() == request.resource.data.phone
        && exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/studentsByPhone/$(request.resource.data.phone))
        && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/studentsByPhone/$(request.resource.data.phone)).data.studentId == request.resource.data.studentId;

      // Student — fresh self-serve: no admin-enrolled record for this phone yet,
      // so this signup batch creates a brand-new student record alongside it.
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'student'
        && !exists(/databases/$(database)/documents/users/$(uid))
        && verifiedPhone() == request.resource.data.phone
        && exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId))
        && !exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/studentsByPhone/$(request.resource.data.phone));

      allow update: if request.auth.uid != uid && hasRole(resource.data.tenantId, ['admin']);
      allow delete: if request.auth.uid != uid && hasRole(resource.data.tenantId, ['admin']);
    }

    // Admin-created, admin-only-readable invites; consumed (deleted) by the
    // matching /users/{uid} mentor-create write in the same client batch.
    match /pendingInvites/{phone} {
      // Only the admin who could have created it can list/read invites for
      // their own tenant — the get()/exists() calls used by the mentor-link
      // rule above bypass this and always have evaluation-time read access.
      allow read: if hasRole(resource.data.tenantId, ['admin']);
      allow create, delete: if signedIn() && hasRole(request.resource.data.tenantId, ['admin']);
      allow update: if false;
    }

    // Public-safe projection for the pre-login referral banner — name only,
    // never the full student record (that stays fully tenant/role-gated below).
    match /tenants/{tid}/referralCodes/{code} {
      allow read: if true;
      allow write: if hasRole(tid, ['admin', 'mentor']);
    }

    match /tenants/{tid}/referralVisits/{id} {
      allow create: if request.resource.data.keys().hasOnly(['refCode','referrerId','referrerName','enrollmentNo','clickedAt']);
      allow read, update, delete: if hasRole(tid, ['admin']);
    }

    // ── Core operational data — admin/mentor staff, student self-scoped read ─
    match /tenants/{tid}/students/{sid} {
      allow read: if hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, sid);
      // Fresh self-registration creates their own student doc pre-`users`
      // (only reachable when no studentsByPhone mapping exists yet — see below).
      allow create: if (hasRole(tid, ['admin','mentor'])
        || (signedIn() && !exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && verifiedPhone() == request.resource.data.phone))
        && studentCapRespectedOnCreate(tid);
      // Student may complete their own profile (name/address/dob) once, staff can edit anytime.
      allow update: if (hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, sid))
        && studentCapRespectedOnUpdate(tid);
      allow delete: if hasRole(tid, ['admin']);
    }

    // Phone -> studentId index. Lets a first-time OTP sign-in find an existing
    // admin-enrolled student record to link to, instead of creating a duplicate.
    match /tenants/{tid}/studentsByPhone/{phone} {
      allow read: if hasRole(tid, ['admin','mentor']);
      allow create: if hasRole(tid, ['admin','mentor'])
        || (signedIn() && !exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && verifiedPhone() == phone);
      allow update: if hasRole(tid, ['admin','mentor']);
      allow delete: if hasRole(tid, ['admin']);
    }

    match /tenants/{tid}/payments/{id} {
      allow read:  if hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, resource.data.studentId);
      allow write: if hasRole(tid, ['admin','mentor']);
    }

    match /tenants/{tid}/attendance/{id} {
      allow read:  if hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, resource.data.studentId);
      allow create, update: if hasRole(tid, ['admin','mentor']);
      allow delete: if hasRole(tid, ['admin']);
    }

    match /tenants/{tid}/drivingTests/{id} {
      allow read:  if hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, resource.data.studentId);
      allow write: if hasRole(tid, ['admin','mentor']);
    }

    match /tenants/{tid}/feeAdjustments/{id} {
      allow read:  if hasRole(tid, ['admin','mentor']) || isStudentSelf(tid, resource.data.studentId);
      allow write: if hasRole(tid, ['admin','mentor']);
    }

    match /tenants/{tid}/referrals/{id} {
      allow read, write: if hasRole(tid, ['admin','mentor']);
    }

    // Subscription (school-pays-Sarathi) payment records — written only by
    // the Cloudflare Worker's Admin SDK path after a verified Cashfree
    // payment; never by any client.
    match /tenants/{tid}/subscriptionPayments/{id} {
      allow read: if hasRole(tid, ['admin']) || isSuperadmin();
      allow write: if false;
    }

    // School-to-school referral credits. Created only by the Worker (Admin
    // SDK) when a referred school pays for the first time; superadmin marks
    // them paid out (cash) from the superadmin panel — a normal client write.
    match /tenants/{tid}/referralPayouts/{id} {
      allow read: if hasRole(tid, ['admin']) || isSuperadmin();
      allow create: if false;
      allow update: if isSuperadmin();
      allow delete: if false;
    }

    // ── Reference/master data & scheduling — staff only ─────────────────────
    match /tenants/{tid}/vehicleClasses/{id}     { allow read, write: if hasRole(tid, ['admin','mentor']); }
    match /tenants/{tid}/dlAuthorities/{id}      { allow read, write: if hasRole(tid, ['admin','mentor']); }
    match /tenants/{tid}/trainingVehicles/{id}   { allow read, write: if hasRole(tid, ['admin','mentor']); }
    match /tenants/{tid}/rosterSlots/{id}        { allow read, write: if hasRole(tid, ['admin','mentor']); }
    match /tenants/{tid}/counters/{id}           { allow read, write: if hasRole(tid, ['admin','mentor']); }
  }
}
